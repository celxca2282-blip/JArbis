# OpenRouter API (скопируйте в .env и укажите свой ключ)
OPENAI_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=deepseek/deepseek-chat

# Распознавание речи (Whisper / faster-whisper)
# medium точнее small; на CPU используйте STT_FORCE_CPU=true
STT_MODEL_NAME=medium
STT_COMPUTE_TYPE=auto
STT_FORCE_CPU=false
STT_BEAM_SIZE=3
STT_USE_VAD_FILTER=true
# STT_INPUT_DEVICE=1
STT_SILENCE_DURATION_SEC=1.0
STT_ENERGY_THRESHOLD=0.008
STT_WAIT_SPEECH_TIMEOUT_SEC=4.0
STT_MAX_RECORD_DURATION_SEC=12.0
STT_POST_ACTIVATION_DELAY_SEC=0.35
STT_LOW_CONFIDENCE_THRESHOLD=-0.82
STT_LOW_CONFIDENCE_MARGIN=0.06
STT_RETRY_ON_LOW_CONFIDENCE=false
STT_PROMPT_APP_LIMIT=40

# Синтез речи (edge-tts)
# Голоса: ru-RU-DmitryNeural, ru-RU-SvetlanaNeural
TTS_ENGINE=piper
PIPER_VOICE=ru_RU-ruslan-medium
TTS_VOICE=ru-RU-DmitryNeural
TTS_SAPI_VOICE=
SILERO_SPEAKER=eugene
SILERO_MODEL=v4_ru
SILERO_SPEED=1.0
EDGE_TTS_LOCALE=ru
TTS_RATE=+0%
TTS_PITCH=+0Hz
TTS_RATE=+8%
TTS_PITCH=+0Hz
TTS_START_PAUSE_MS=150

# Голосовая активация
WAKE_WORD_ENGINE=vosk
WAKE_WORD_NAME=джарвис

# Отладка без микрофона
DEBUG_TEXT_MODE=false

# Индекс приложений из меню «Пуск» + UWP
APP_INDEX_MAX_AGE_HOURS=24
APP_SCAN_ON_STARTUP=true
APP_SCAN_UWP=true
APP_FUZZY_MIN_SCORE=0.6
APP_FUZZY_MIN_SCORE_MULTIWORD=0.72
